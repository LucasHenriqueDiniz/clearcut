{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ClearCut",
  "version": "0.1.0",
  "identifier": "com.local.clearcut",
  "build": {
    "beforeDevCommand": "cd ../frontend && npm run dev",
    "beforeBuildCommand": "python ../scripts/build-backend-sidecar.py && cd ../frontend && npm run build",
    "devUrl": "http://localhost:3000",
    "frontendDist": "../frontend/out"
  },
  "app": {
    "security": {
      "csp": {
        "default-src": "'self' ipc: http://ipc.localhost",
        "connect-src": "'self' ipc: http://ipc.localhost http://127.0.0.1:* http://localhost:*",
        "img-src": "'self' asset: http://asset.localhost blob: data: http://127.0.0.1:* http://localhost:*"
      },
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "windows": [
      {
        "label": "main",
        "title": "ClearCut",
        "width": 1460,
        "height": 980,
        "minWidth": 1180,
        "minHeight": 760,
        "resizable": true,
        "decorations": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "appimage"],
    "resources": {
      "resources/backend/": "backend/"
    },
    "icon": [
      "../frontend/public/icon.ico",
      "../frontend/public/icon.png"
    ]
  }
}
